# Server
PORT=3005
NODE_ENV=development

# PostgreSQL
DB_HOST=postgres-reservation
DB_PORT=5432
DB_NAME=reservation_db
DB_USER=reservation_user
DB_PASSWORD=reservation_password

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_EXCHANGE=hotel_events

# JWT (verify only — same secret as auth-service)
JWT_SECRET=change_me_in_production_min_32_chars

# Internal token (shared across services)
INTERNAL_TOKEN=super_secret_internal_token

# Downstream service URLs (internal calls)
HOTELS_SERVICE_URL=http://hotels-service:3003
BILLING_SERVICE_URL=http://billing-service:3007
GUEST_SERVICE_URL=http://guest-service:3004

# Portal token lifespan (hours)
PORTAL_TOKEN_EXPIRES_HOURS=48
