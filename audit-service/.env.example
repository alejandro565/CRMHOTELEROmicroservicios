# Server
PORT=3008
NODE_ENV=development

# PostgreSQL
DB_HOST=postgres-audit
DB_PORT=5432
DB_NAME=audit_db
DB_USER=audit_user
DB_PASSWORD=audit_password

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_EXCHANGE=hotel_events

# JWT (verify only)
JWT_SECRET=change_me_in_production_min_32_chars

# Internal token
INTERNAL_TOKEN=super_secret_internal_token

# Anomaly detection threshold
ANOMALY_VOID_THRESHOLD=5
ANOMALY_WINDOW_MINUTES=60
