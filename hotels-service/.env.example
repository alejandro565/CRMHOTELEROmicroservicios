# Server
PORT=3003
NODE_ENV=development

# PostgreSQL
DB_HOST=postgres-hotels
DB_PORT=5432
DB_NAME=hotels_db
DB_USER=hotels_user
DB_PASSWORD=hotels_password

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_EXCHANGE=hotel_events

# JWT (same secret as auth-service — used only for VERIFICATION, never signing)
JWT_SECRET=change_me_in_production_min_32_chars

# Internal token (shared with other services)
INTERNAL_TOKEN=super_secret_internal_token
