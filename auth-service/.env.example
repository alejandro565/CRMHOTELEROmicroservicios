# Server
PORT=3002
NODE_ENV=development

# PostgreSQL
DB_HOST=postgres-auth
DB_PORT=5432
DB_NAME=auth_db
DB_USER=auth_user
DB_PASSWORD=auth_password

# JWT
JWT_SECRET=change_me_in_production_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES_DAYS=7

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_EXCHANGE=hotel_events

# Internal security (shared with saas-service)
INTERNAL_TOKEN=super_secret_internal_token

# Communication service (for reset password emails)
COMMUNICATION_SERVICE_URL=http://communication-service:3005
