# Server
PORT=3007
NODE_ENV=development

# PostgreSQL
DB_HOST=postgres-billing
DB_PORT=5432
DB_NAME=billing_db
DB_USER=billing_user
DB_PASSWORD=billing_password

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_EXCHANGE=hotel_events

# JWT (verify only)
JWT_SECRET=change_me_in_production_min_32_chars

# Internal token
INTERNAL_TOKEN=super_secret_internal_token

# SIN (Bolivia tax authority) - stub for now
SIN_API_URL=https://piloto.siat.agetic.gob.bo
SIN_API_TOKEN=sin_api_token_here

# Communication service
COMMUNICATION_SERVICE_URL=http://communication-service:3006
